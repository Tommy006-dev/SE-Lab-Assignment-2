@model OrderManagement.Models.Item
@{
    ViewBag.Title = "Thêm Sản Phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h4 class="m-0">Thêm Sản Phẩm Mới</h4>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Create", "Items", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="form-group row mb-3">
                        <label class="col-sm-3 col-form-label font-weight-bold">Tên sản phẩm (*):</label>
                        <div class="col-sm-9">
                            @Html.EditorFor(model => model.ItemName, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                            @Html.ValidationMessageFor(model => model.ItemName, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group row mb-3">
                        <label class="col-sm-3 col-form-label font-weight-bold">Kích cỡ:</label>
                        <div class="col-sm-9">
                            @Html.EditorFor(model => model.Size, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                    </div>

                    <div class="form-group row mb-3">
                        <label class="col-sm-3 col-form-label font-weight-bold">Đơn giá:</label>
                        <div class="col-sm-9">
                            @Html.EditorFor(model => model.Price, new { htmlAttributes = new { @class = "form-control", type = "number" } })
                        </div>
                    </div>

                    <div class="form-group row mb-3">
                        <label class="col-sm-3 col-form-label font-weight-bold">Mô tả:</label>
                        <div class="col-sm-9">
                            @Html.TextAreaFor(model => model.Description, new { @class = "form-control", rows = "3" })
                        </div>
                    </div>

                    <div class="form-group row mt-4">
                        <div class="col-sm-9 offset-sm-3">
                            <button type="submit" class="btn btn-success">Lưu Sản Phẩm</button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary">Quay Lại</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
@model OrderManagement.Models.Agent
@{
    ViewBag.Title = "Thêm Đại Lý";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow border-info">
            <div class="card-header bg-info text-white">
                <h4 class="m-0">Thêm Đại Lý Mới</h4>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Create", "Agents", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="form-group row mb-3">
                        <label class="col-sm-3 col-form-label font-weight-bold">Tên đại lý (*):</label>
                        <div class="col-sm-9">
                            @Html.EditorFor(model => model.AgentName, new { htmlAttributes = new { @class = "form-control", required = "required", placeholder = "Nhập tên đại lý..." } })
                            @Html.ValidationMessageFor(model => model.AgentName, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group row mb-3">
                        <label class="col-sm-3 col-form-label font-weight-bold">Địa chỉ:</label>
                        <div class="col-sm-9">
                            @Html.TextAreaFor(model => model.Address, new { @class = "form-control", rows = "3", placeholder = "Nhập địa chỉ giao hàng..." })
                        </div>
                    </div>

                    <div class="form-group row mt-4">
                        <div class="col-sm-9 offset-sm-3">
                            <button type="submit" class="btn btn-info px-4">Lưu Đại Lý</button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary px-4 ml-2">Quay Lại</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

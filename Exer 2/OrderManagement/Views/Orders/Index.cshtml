@model IEnumerable<OrderManagement.Models.Order>
@{
    ViewBag.Title = "Danh sách đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card shadow mb-4 mt-4 border-primary">
    <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
        <h4 class="m-0 font-weight-bold">Danh Sách Đơn Hàng</h4>
        <a href="@Url.Action("Create")" class="btn btn-light text-primary font-weight-bold shadow-sm">
            + Tạo Đơn Hàng Mới
        </a>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info shadow-sm">
                Chưa có đơn hàng nào.
                <a href="@Url.Action("Create")" class="alert-link text-decoration-underline">Tạo đơn hàng đầu tiên</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped">
                    <thead class="thead-dark">
                        <tr>
                            <th class="text-center align-middle">Mã đơn</th>
                            <th class="align-middle">Ngày đặt</th>
                            <th class="align-middle">Đại lý</th>
                            <th class="align-middle">Địa chỉ</th>
                            <th class="text-center align-middle">Số SP</th>
                            <th class="text-right align-middle">Tổng tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            decimal total = order.OrderDetails
                                .Sum(d => (d.Quantity ?? 0) * (d.UnitAmount ?? 0));
                            int soSP = order.OrderDetails.Count();

                            <tr>
                                <td>
                                    @order.OrderID
                                </td>
                                <td class="align-middle">
                                    @(order.OrderDate.ToString("dd/MM/yyyy"))
                                </td>
                                <td class="align-middle text-primary font-weight-bold">
                                    @(order.Agent?.AgentName)
                                </td>
                                <td class="align-middle">
                                    <small class="text-dark">
                                        @(order.Agent?.Address)
                                    </small>
                                </td>
                                <td class="text-center align-middle">
                                    <span class="text-dark" style="font-size: 14px;">@soSP</span>
                                </td>
                                <td class="text-right align-middle">
                                    <strong class="text-danger">
                                        @total.ToString("N0") VNĐ
                                    </strong>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="bg-light">
                            <td colspan="5" class="text-right align-middle">
                                <strong class="text-uppercase">Tổng doanh thu:</strong>
                            </td>
                            <td class="text-right align-middle">
                                <strong class="text-danger" style="font-size: 1.1rem;">
                                    @(Model.Sum(o => o.OrderDetails
                                        .Sum(d => (d.Quantity ?? 0) * (d.UnitAmount ?? 0)))
                                    .ToString("N0")) VNĐ
                                </strong>
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>
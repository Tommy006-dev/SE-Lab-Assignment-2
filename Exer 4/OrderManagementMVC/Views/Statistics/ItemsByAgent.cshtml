@{
    ViewData["Title"] = "Sản phẩm theo đại lý";
}

<h4 class="mb-3">📦 Sản phẩm được mua bởi đại lý</h4>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select name="agentId" class="form-select">
            <option value="">-- Chọn đại lý --</option>
            @foreach (var agent in ViewBag.Agents)
            {
                <option value="@agent.AgentID"
                        selected="@(ViewBag.SelectedAgent == agent.AgentID)">
                    @agent.AgentName
                </option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">🔍 Lọc</button>
    </div>
</form>

@if (Model != null)
{
    <table class="table table-bordered">
        <thead class="table-info">
            <tr>
                <th>Đại lý</th>
                <th>Sản phẩm</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Ngày đặt</th>
            </tr>
        </thead>
        <tbody>
            @foreach (dynamic row in Model)
            {
                <tr>
                    <td>@row.AgentName</td>
                    <td>@row.ItemName</td>
                    <td>@row.Quantity</td>
                    <td>@row.UnitAmount?.ToString("N0") VNĐ</td>
                    <td>@row.OrderDate.ToString("dd/MM/yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}
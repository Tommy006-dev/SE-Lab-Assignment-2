@model OrderManagementMVC.Models.Order

@{
    ViewData["Title"] = "In đơn hàng";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đơn hàng #@Model.OrderID</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            body { font-family: Arial, sans-serif; }
            @@media print {
                .no-print { display: none; }
            }
    </style>
</head>
<body class="p-4">

    <div class="text-center mb-3">
        <h3>HÓA ĐƠN ĐẶT HÀNG</h3>
        <hr />
    </div>

    <div class="row mb-3">
        <div class="col-6">
            <p><strong>Mã đơn hàng:</strong> #@Model.OrderID</p>
            <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy")</p>
        </div>
        <div class="col-6">
            <p><strong>Đại lý:</strong> @Model.Agent?.AgentName</p>
            <p><strong>Địa chỉ:</strong> @Model.Agent?.Address</p>
        </div>
    </div>

    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Tên sản phẩm</th>
                <th>Kích cỡ</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @{
                int stt = 1;
            }
            @foreach (var detail in Model.OrderDetails ?? new List<OrderManagementMVC.Models.OrderDetail>())
            {
                <tr>
                    <td>@stt</td>
                    <td>@detail.Item?.ItemName</td>
                    <td>@detail.Item?.Size</td>
                    <td>@detail.Quantity</td>
                    <td>@detail.UnitAmount?.ToString("N0") VNĐ</td>
                    <td>@((detail.Quantity * detail.UnitAmount)?.ToString("N0")) VNĐ</td>
                </tr>
                stt++;
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="5" class="text-end"><strong>Tổng cộng:</strong></td>
                <td>
                    <strong>
                        @(Model.OrderDetails?
                            .Sum(d => d.Quantity * d.UnitAmount)
                            ?.ToString("N0")) VNĐ
                    </strong>
                </td>
            </tr>
        </tfoot>
    </table>

    <div class="no-print mt-3">
        <button onclick="window.print()" class="btn btn-primary">🖨️ In hóa đơn</button>
        <a asp-action="Index" class="btn btn-secondary">← Quay lại</a>
    </div>

</body>
</html>
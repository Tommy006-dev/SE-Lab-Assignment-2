@model OrderManagementMVC.Models.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null; // Không dùng layout chung
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white text-center">
                        <h4>Order Management</h4>
                        <small>Đăng nhập hệ thống</small>
                    </div>
                    <div class="card-body">
                        <form asp-action="Login" method="post">
                            <div asp-validation-summary="All" class="text-danger mb-2"></div>

                            <div class="mb-3">
                                <label asp-for="UserName" class="form-label">Tên đăng nhập</label>
                                <input asp-for="UserName" class="form-control" placeholder="Nhập username" />
                                <span asp-validation-for="UserName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label">Mật khẩu</label>
                                <input asp-for="Password" class="form-control" placeholder="Nhập password" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>